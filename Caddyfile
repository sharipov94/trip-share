# Прод reverse-proxy для trip-radar.ru (системный Caddy на сервере).
# Лежит на сервере в /etc/caddy/Caddyfile — здесь версионируемая копия.
# Caddy сам выпускает и продлевает TLS.
trip-radar.ru {
    # Access-логи в journald (читать: journalctl -u caddy | grep '"uri":"/api')
    log {
        format json
    }

    encode gzip

    # API → NestJS на localhost
    handle /api/* {
        reverse_proxy 127.0.0.1:3000
    }

    # Загруженные фото с диска
    handle /uploads/* {
        root * /opt/travelmate
        file_server
    }

    # Хешированные ассеты фронта — кэшируем навсегда
    handle /assets/* {
        root * /opt/travelmate/web
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    # SPA: всё остальное → index.html (без кэша, чтобы новые сборки подхватывались)
    handle {
        root * /opt/travelmate/web
        header Cache-Control "no-store, no-cache, must-revalidate"
        try_files {path} /index.html
        file_server
    }
}

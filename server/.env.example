# Скопируй в .env и заполни.

# PostgreSQL
DATABASE_URL=postgres://travelmate:travelmate@localhost:5432/travelmate
# Для быстрого старта без миграций — создаёт таблицы из entities (только dev!)
DB_SYNCHRONIZE=true

# Telegram бот (нужен реальный токен от @BotFather для валидации initData)
BOT_TOKEN=123456:put-your-bot-token-here
# Username бота (без @) — для инвайт-ссылок
BOT_USERNAME=Share_trip_bot
# Допустимый возраст initData в секундах (replay-защита)
INITDATA_TTL=86400

# JWT — задай 32+ случайных символа (напр. `openssl rand -hex 32`).
# Сервер откажется стартовать в production со слабым/дефолтным секретом.
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Шифрование payment_details (32 байта hex). Сгенерируй: `openssl rand -hex 32`
ENCRYPTION_KEY=

# Dev-вход без Telegram (POST /auth/dev) — ПОЛНЫЙ обход аутентификации.
# Держи false. Включай только локально; в production игнорируется (гейт по NODE_ENV).
DEV_FAKE_AUTH=false

PORT=3000
